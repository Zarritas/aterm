{
  "name": "agent-sessions",
  "displayName": "Agent Sessions",
  "description": "Lista, previsualiza y reanuda tus sesiones de agentes de código (Claude Code, Codex, OpenCode, Gemini) en el terminal integrado.",
  "version": "1.0.0",
  "publisher": "Zarritas",
  "author": "Jesús Lorenzo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zarritas/aterm.git"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "atermSessions",
          "title": "Agent Sessions",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "atermSessions": [
        {
          "type": "webview",
          "id": "agentSessions.sessions",
          "name": "Sesiones",
          "icon": "media/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "agentSessions.refresh",
        "title": "Refrescar",
        "category": "Agent Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "agentSessions.newSession",
        "title": "Nueva sesión",
        "category": "Agent Sessions",
        "icon": "$(add)"
      },
      {
        "command": "agentSessions.smartLaunch",
        "title": "Lanzar agente recomendado",
        "category": "Agent Sessions",
        "icon": "$(sparkle)"
      },
      {
        "command": "agentSessions.setFilter",
        "title": "Filtrar sesiones…",
        "category": "Agent Sessions",
        "icon": "$(filter)"
      },
      {
        "command": "agentSessions.searchContent",
        "title": "Buscar en contenido…",
        "category": "Agent Sessions",
        "icon": "$(search)"
      },
      {
        "command": "agentSessions.clearFilter",
        "title": "Limpiar filtro",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.setGroupBy",
        "title": "Agrupar por…",
        "category": "Agent Sessions",
        "icon": "$(list-tree)"
      },
      {
        "command": "agentSessions.import",
        "title": "Importar .zip…",
        "category": "Agent Sessions",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "agentSessions.renameProject",
        "title": "Renombrar proyecto…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.setProjectColor",
        "title": "Color del proyecto…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.clearProjectMetadata",
        "title": "Limpiar alias/color del proyecto",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.launchParallel",
        "title": "Lanzar comparativa paralela…",
        "category": "Agent Sessions",
        "icon": "$(repo-forked)"
      },
      {
        "command": "agentSessions.compareWorktrees",
        "title": "Comparar resultados de worktrees…",
        "category": "Agent Sessions",
        "icon": "$(diff)"
      },
      {
        "command": "agentSessions.cleanupWorktrees",
        "title": "Limpiar worktrees de comparativa…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.backupCatalog",
        "title": "Backup del catálogo…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.restoreCatalog",
        "title": "Restaurar catálogo…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.runTemplate",
        "title": "Lanzar plantilla…",
        "category": "Agent Sessions",
        "icon": "$(rocket)"
      },
      {
        "command": "agentSessions.saveTemplate",
        "title": "Guardar plantilla…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.manageTemplates",
        "title": "Gestionar plantillas…",
        "category": "Agent Sessions"
      },
      {
        "command": "agentSessions.manageTagCatalog",
        "title": "Gestionar catálogo de etiquetas…",
        "category": "Agent Sessions",
        "icon": "$(tag)"
      },
      {
        "command": "agentSessions.quickActions",
        "title": "Acciones rápidas de sesión…",
        "category": "Agent Sessions",
        "icon": "$(list-selection)"
      },
      {
        "command": "agentSessions.configureMcp",
        "title": "Configurar servidor MCP…",
        "category": "Agent Sessions",
        "icon": "$(server-process)"
      }
    ],
    "keybindings": [
      {
        "command": "agentSessions.quickActions",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      }
    ],
    "terminal": {
      "profiles": [
        {
          "id": "agentSessions.terminal.claude",
          "title": "Claude Code",
          "icon": "comment-discussion"
        },
        {
          "id": "agentSessions.terminal.codex",
          "title": "Codex",
          "icon": "comment-discussion"
        },
        {
          "id": "agentSessions.terminal.opencode",
          "title": "OpenCode",
          "icon": "comment-discussion"
        },
        {
          "id": "agentSessions.terminal.gemini",
          "title": "Gemini",
          "icon": "comment-discussion"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "agentSessions.newSession",
          "when": "view == agentSessions.sessions",
          "group": "navigation@1"
        },
        {
          "command": "agentSessions.import",
          "when": "view == agentSessions.sessions",
          "group": "navigation@2"
        },
        {
          "command": "agentSessions.launchParallel",
          "when": "view == agentSessions.sessions",
          "group": "navigation@3"
        },
        {
          "command": "agentSessions.refresh",
          "when": "view == agentSessions.sessions",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Agent Sessions",
      "properties": {
        "agentSessions.cliPath": {
          "type": "string",
          "default": "agent-sessions-cli",
          "description": "Ruta al binario sidecar `agent-sessions-cli`. Por defecto se busca en el PATH."
        },
        "agentSessions.openInEditor": {
          "type": "boolean",
          "default": true,
          "description": "Abrir las sesiones en el área del editor (pestaña a tamaño completo) en vez del panel inferior."
        },
        "agentSessions.closeOnExit": {
          "type": "boolean",
          "default": true,
          "description": "Cerrar el terminal completo cuando la sesión del agente termina (ejecuta `exit` al acabar)."
        },
        "agentSessions.notifyOnIdle": {
          "type": "boolean",
          "default": true,
          "description": "Notificar cuando una sesión activa pasa de “trabajando” a “esperando input”."
        },
        "agentSessions.notifyOnFinish": {
          "type": "boolean",
          "default": true,
          "description": "Notificar cuando una sesión deja de estar activa (proceso terminado)."
        },
        "agentSessions.pollIntervalSec": {
          "type": "integer",
          "default": 5,
          "minimum": 2,
          "maximum": 120,
          "description": "Cada cuántos segundos consultar el estado en vivo de las sesiones (usado para los contadores y notificaciones)."
        },
        "agentSessions.costAlertDaily": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Umbral diario de gasto en USD. Si el coste total de las sesiones cuya última actividad fue hoy lo supera, el panel muestra una alerta. 0 desactiva la alerta."
        },
        "agentSessions.scanProviders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "codex",
              "opencode",
              "gemini"
            ]
          },
          "uniqueItems": true,
          "default": [
            "claude",
            "codex",
            "opencode",
            "gemini"
          ],
          "description": "Proveedores visibles en el panel. Filtro de visualización: el sidecar sigue escaneando el disco, pero las sesiones de un proveedor no marcado se ocultan (y no cuentan en los contadores ni en el coste). Lista vacía = se muestran todos."
        },
        "agentSessions.fetchStatus": {
          "type": "boolean",
          "default": true,
          "description": "Consultar por red el estado del servicio (statuspage de Claude/OpenAI) y mostrar la cuota del proveedor. Desactívalo para trabajar sin tráfico de red."
        },
        "agentSessions.refreshSec": {
          "type": "integer",
          "default": 120,
          "minimum": 0,
          "maximum": 600,
          "description": "Cada cuántos segundos re-escanear el disco completo para detectar sesiones nuevas y cambios de coste/contexto/modelo. 0 desactiva el auto-refresco completo; valores entre 1 y 14 se ajustan a 15."
        },
        "agentSessions.tagCatalog": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Catálogo de etiquetas predefinidas. Aparecen como opciones marcables al asignar etiquetas a una sesión, para no tener que escribirlas a mano. Gestiónalo con el comando «Agent Sessions: Gestionar catálogo de etiquetas» o editando esta lista directamente."
        },
        "agentSessions.groupBy": {
          "type": "string",
          "enum": [
            "provider",
            "project",
            "cascade",
            "date"
          ],
          "enumDescriptions": [
            "Una rama por proveedor (Claude/Codex/…); plano dentro.",
            "Una rama por proyecto (cwd); sesiones de cualquier proveedor dentro.",
            "Proveedor → proyecto → sesión.",
            "Por fecha: Hoy / Ayer / Esta semana / Este mes / Más antiguo."
          ],
          "default": "provider",
          "description": "Cómo agrupar las sesiones en el panel."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "scripts/build-vsix.sh",
    "publish:ovsx": "ovsx publish",
    "build:icon": "node scripts/build-icon.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "ovsx": "^0.10.0",
    "typescript": "^5.4.0"
  }
}
